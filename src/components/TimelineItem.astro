---
/**
 * src/components/TimelineItem.astro
 * Un paso individual en la línea de tiempo del proyecto
 */
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  badge?: string;
  image: ImageMetadata;
  index: number;
  total: number;
}

const { title, description, badge, image, index, total } = Astro.props;
const isLast = index === total - 1;
---

<div
  class="relative pl-8 sm:pl-32 py-8 sm:py-16 timeline-item opacity-0 translate-y-12"
>
  <!-- ── LINEA VERTICAL CENTRAL Y DOT ── -->
  <div
    class="absolute left-0 sm:left-16 top-0 bottom-0 flex flex-col items-center"
  >
    <!-- Línea superior -->
    <div
      class={`w-0.5 bg-gradient-to-b from-border/50 to-primary/40 flex-grow ${index === 0 ? "hidden" : ""}`}
    >
    </div>

    <!-- El "punto" en la línea del tiempo -->
    <div
      class="w-8 h-8 sm:w-12 sm:h-12 rounded-full border-4 border-background bg-primary shadow-xl shadow-primary/30 z-10 flex items-center justify-center shrink-0 my-6 sm:my-10 relative group"
    >
      <div
        class="absolute inset-0 rounded-full bg-primary animate-ping opacity-20 group-hover:opacity-40"
      >
      </div>
      <span class="absolute text-xs font-black text-primary-foreground">
        {index + 1}
      </span>
    </div>

    <!-- Línea inferior -->
    <div
      class={`w-0.5 bg-gradient-to-b from-primary/40 to-border/50 flex-grow ${isLast ? "hidden" : ""}`}
    >
    </div>
  </div>

  <!-- ── CONTENIDO DEL TIMELINE (Grid texto + imagen) ── -->
  <div
    class="grid lg:grid-cols-12 gap-8 items-start relative before:absolute before:inset-0 before:-left-4 sm:before:-left-12 before:bg-card/50 before:rounded-[2.5rem] before:-z-10 before:border before:border-border/40 before:opacity-0 hover:before:opacity-100 before:transition-all before:duration-500 p-4 sm:p-10"
  >
    <!-- Texto -->
    <div class="lg:col-span-4 flex flex-col gap-4">
      {
        badge && (
          <span class="inline-flex items-center self-start px-3 py-1 text-[10px] font-mono tracking-widest uppercase rounded-full bg-primary/10 text-primary border border-primary/20">
            {badge}
          </span>
        )
      }
      <h3
        class="text-2xl sm:text-3xl font-extrabold tracking-tight text-foreground"
      >
        {title}
      </h3>
      <p class="text-muted-foreground text-sm sm:text-base leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Imagen (Captura) -->
    <div class="lg:col-span-8 group relative">
      <div
        class="absolute -inset-2 bg-gradient-to-r from-primary/10 to-blue-500/10 rounded-3xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"
      >
      </div>

      <div
        class="relative rounded-2xl border border-border/50 bg-background/50 overflow-hidden shadow-xl ring-1 ring-white/10"
      >
        <!-- Barra de herramientas (decorativa mac-os) -->
        <div
          class="h-8 bg-muted/40 border-b border-border/40 flex items-center px-4 gap-1.5 backdrop-blur-sm"
        >
          <div class="w-2.5 h-2.5 rounded-full bg-red-400/80"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-green-400/80"></div>
        </div>

        <img
          src={image.src}
          alt={title}
          width={image.width}
          height={image.height}
          loading="lazy"
          class="w-full object-cover aspect-[16/10] sm:aspect-[16/9] transition-transform duration-700 group-hover:scale-105"
        />
      </div>
    </div>
  </div>
</div>

<script>
  // Animación de aparición (Scroll reveal)
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-12");
          entry.target.classList.add("opacity-100", "translate-y-0");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -100px 0px" },
  );

  document
    .querySelectorAll(".timeline-item")
    .forEach((el) => observer.observe(el));
</script>

<style>
  .timeline-item {
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>

---
import Main from '../layouts/main.astro';
import { Navbar } from '@/components/Navbar';
import { Footer } from '@/components/Footer';
import ImageTextSection from '@/components/ImageTextSection.astro';
import { projects } from '@/lib/projects';
---

<Main title="Proyectos | MiraCode — Software a medida">
  <Navbar client:load />

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative pt-24 overflow-hidden">
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-gradient-to-b from-primary/20 via-blue-500/10 to-transparent rounded-full blur-3xl"></div>
    </div>

    <div class="container mx-auto px-4 md:px-6 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary/30 bg-primary/10 text-primary text-xs font-bold mb-6 hero-fade">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
        Nuestros Sistemas
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-6 hero-fade" style="transition-delay:80ms">
        <span class="bg-gradient-to-r from-foreground via-foreground to-muted-foreground bg-clip-text text-transparent">
          Soluciones de software
        </span>
        <br />
        <span class="bg-gradient-to-r from-primary via-blue-400 to-cyan-400 bg-clip-text text-transparent">
          creadas para la vida real
        </span>
      </h1>

      <p class="max-w-3xl mx-auto text-lg md:text-xl text-muted-foreground leading-relaxed hero-fade" style="transition-delay:160ms">
        Proyectos escalables, modernos y diseñados para resolver problemas específicos. Entrá a cada uno para ver capturas y más información de los sistemas que construimos.
      </p>
    </div>
  </section>

  <!-- ── LISTADO DE PROYECTOS (ImageTextSection para cada uno) ── -->
  <main class="flex flex-col">
    {projects.map((p, index) => (
      <div class={`md:py-12`}>
        <ImageTextSection
          image={p.image}
          title={p.title}
          description={p.shortDesc}
          imagePosition={index % 2 === 0 ? 'left' : 'right'}
          badge={p.category}
          features={p.features.slice(0, 3)} 
          ctaPrimary={{
            label: 'Ver capturas y detalles',
            href: `/proyectos/${p.id}`,
            triggerConfetti: false
          }}
          ctaSecondary={undefined}
        />
      </div>
    ))}
  </main>

  <Footer />
</Main>

<script>
  // ── Hero fade-in ─────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.hero-fade').forEach(el => {
    const delay = parseInt(el.style.transitionDelay || '0') || 0;
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    el.style.transition = 'opacity 0.6s ease, transform 0.6s cubic-bezier(.22,1,.36,1)';
    setTimeout(() => {
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, 100 + delay);
  });
</script>

<style>
  .bg-clip-text { -webkit-background-clip: text; background-clip: text; }
</style>
---
// src/pages/proyectos/[id].astro
import Main from '../../layouts/main.astro';
import { Navbar } from '@/components/Navbar';
import { Footer } from '@/components/Footer';
import { projects, getProject } from '@/lib/projects';

// Nuevo componente de Timeline
import TimelineItem from '@/components/TimelineItem.astro';

// Genera una ruta estática por cada proyecto
export function getStaticPaths() {
  return projects.map(p => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const project = getProject(id!);

if (!project) return Astro.redirect('/404');

// Imagen placeholder — cuando tengas las reales, importalas y asigalas al frontmatter
import dashImg from '@/assets/dashboard.png';

// Fallback temporal usando la misma imagen
const coverImage = dashImg;
const sectionImages = project.sections.map(() => dashImg);
---

<Main title={`${project.title} | MiraCode`}>
  <!-- Navbar sobre la imagen -->
  <div class="fixed top-0 w-full z-50">
    <Navbar client:load />
  </div>

  <!-- ── HERO: IMAGEN GIGANTE ("LA CARA") ────────────────────── -->
  <section class="relative w-full h-[85vh] min-h-[600px] flex items-end justify-center overflow-hidden bg-black">
    
    <!-- Imagen de fondo que ocupa todo el Hero -->
    <div class="absolute inset-0 z-0">
      <img
        src={coverImage.src}
        alt={`${project.title} Cover`}
        width={coverImage.width}
        height={coverImage.height}
        class="w-full h-full object-cover opacity-50 scale-105 animate-image-reveal"
      />
      <!-- Gradientes encima de la imagen para legibilidad y estética -->
      <div class={`absolute inset-0 bg-gradient-to-t from-background via-background/80 to-transparent z-10`}></div>
      <div class={`absolute inset-0 bg-gradient-to-b ${project.color} opacity-20 z-10 mix-blend-overlay`}></div>
    </div>

    <!-- Contenido del Hero (Abajo) -->
    <div class="container relative z-20 mx-auto px-4 md:px-6 pb-16 md:pb-24 flex flex-col items-center text-center animate-fade-up">
      
      <!-- Etiquetas -->
      <div class="flex flex-wrap gap-2 justify-center mb-6">
        <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-primary text-primary-foreground shadow-lg shadow-primary/30`}>
          {project.category}
        </span>
      </div>

      <!-- Título Principal -->
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl font-black tracking-tighter text-white mb-6 drop-shadow-2xl">
        {project.title}
      </h1>

      <!-- Descripción corta -->
      <p class="max-w-3xl text-lg md:text-2xl font-medium text-white/90 leading-relaxed drop-shadow-md mb-10">
        {project.shortDesc}
      </p>

      <!-- Botones CTA -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#detalles" class="inline-flex items-center justify-center gap-2 h-12 px-8 rounded-full bg-white text-black font-bold text-sm hover:bg-white/90 transition-all duration-300 hover:scale-105 shadow-xl">
          Explorar sistema
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        </a>
        <a href="/contacto" class="inline-flex items-center justify-center gap-2 h-12 px-8 rounded-full border border-white/30 bg-black/30 backdrop-blur-md text-white font-bold text-sm hover:bg-black/50 transition-all duration-300 hover:border-white/50">
          Quiero algo igual
        </a>
      </div>

    </div>
  </section>

  <!-- ── DETALLES Y CONTEXTO (Shadcn Typography style) ────── -->
  <section id="detalles" class="py-20 bg-background scroll-mt-20">
    <div class="container mx-auto px-4 md:px-6 max-w-4xl">
      <!-- "The Problem" / Descripción completa -->
      <div class="prose prose-invert lg:prose-xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-6">Contexto del Proyecto</h2>
        <p class="text-muted-foreground leading-relaxed text-lg lg:text-xl">
          {project.fullDesc}
        </p>
      </div>

      <!-- Features grid style shadcn cards -->
      <div class="grid sm:grid-cols-2 gap-4">
        {project.features.map(f => (
          <div class="flex items-start gap-4 p-5 rounded-2xl border border-border/50 bg-card/50 backdrop-blur-sm shadow-sm hover:border-primary/50 transition-colors">
            <div class="shrink-0 flex items-center justify-center w-8 h-8 rounded-full bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <span class="text-sm md:text-base font-medium leading-snug text-foreground/90 pt-1">{f}</span>
          </div>
        ))}
      </div>
      
      <!-- Tech Stack -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-12 mb-24">
        <span class="text-sm font-bold text-muted-foreground uppercase tracking-widest mr-2">Stacks:</span>
        {project.tags.map(t => (
          <span class="px-4 py-1.5 text-xs font-semibold rounded-full bg-muted border border-border text-foreground hover:bg-accent cursor-default transition-colors">
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CRONOLOGÍA / RECORRIDO DEL SISTEMA (Timeline) ──────── -->
  <section class="py-12 pb-32 relative overflow-hidden bg-dot-pattern">
    <div class="container mx-auto px-4 md:px-6 max-w-6xl">
      
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight">Recorrido del Sistema</h2>
        <p class="text-muted-foreground mt-4 text-lg">Vistas y flujos principales de la solución implementada.</p>
      </div>

      <!-- Timeline Container -->
      <div class="relative w-full max-w-5xl mx-auto">
        <!-- Línea Guia de fondo (continua) -->
        <div class="absolute left-11 sm:left-[4.5rem] top-10 bottom-10 w-0.5 bg-border/40 -z-10"></div>
        
        <div class="flex flex-col gap-12 sm:gap-4">
          {project.sections.map((section, idx) => (
            <TimelineItem 
              title={section.title}
              description={section.description}
              badge={section.badge}
              image={sectionImages[idx]}
              index={idx}
              total={project.sections.length}
            />
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ── CALL TO ACTION FINAL ──────────────────────────────── -->
  <section class="relative py-24 border-t border-border overflow-hidden">
    <!-- Efecto en el fondo -->
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/10 via-background to-background"></div>

    <div class="container mx-auto px-4 text-center max-w-3xl">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6">
        Llevá tu negocio al próximo nivel
      </h2>
      <p class="text-xl text-muted-foreground mb-10">
        Si tu empresa tiene un desafío similar a {project.title}, podemos diseñar la solución exacta que necesitas.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto" class="inline-flex items-center justify-center gap-2 h-14 px-10 rounded-xl bg-primary text-primary-foreground font-bold text-base shadow-2xl shadow-primary/30 hover:scale-105 transition-transform duration-300">
          Iniciar cotización
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <a href="/proyectos" class="inline-flex items-center justify-center gap-2 h-14 px-10 rounded-xl border-2 border-border bg-transparent hover:bg-muted text-foreground font-bold text-base transition-colors duration-300">
          Ver otros proyectos
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Main>

<style>
  /* Patrón de puntos para el fondo del Timeline */
  .bg-dot-pattern {
    background-image: radial-gradient(hsl(var(--muted-foreground)/0.2) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  /* Animaciones custom para el Hero */
  .animate-image-reveal {
    animation: imageReveal 2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  
  .animate-fade-up {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 1s ease-out 0.3s forwards;
  }

  @keyframes imageReveal {
    from {
      transform: scale(1.1);
      filter: blur(8px) brightness(0.5);
    }
    to {
      transform: scale(1);
      filter: blur(0px) brightness(1);
    }
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

---
// src/pages/proyectos/[id].astro
import Main from "../../layouts/main.astro";
import { Navbar } from "@/components/Navbar";
import { Footer } from "@/components/Footer";
import { projects, getProject } from "@/lib/projects";


// Nuevo componente de Timeline
import TimelineItem from "@/components/TimelineItem.astro";

// Genera una ruta estática por cada proyecto
export function getStaticPaths() {
  return projects.map((p) => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const project = getProject(id!);

if (!project) return Astro.redirect("/404");

// Imagen placeholder para el logo si no hay uno específico
import logoImg from "@/assets/logo.png";

// Preferir video si existe, sino usar imagen como fallback
const coverVideo = project.video ?? project.image;
---

<Main title={`${project.title} | MiraCode`}>
  <!-- Navbar sobre la imagen -->
  <div class="fixed top-0 w-full z-50">
    <Navbar client:load />
  </div>

  <!-- ── HERO: IMAGEN GIGANTE ("LA CARA") ────────────────────── -->
  <section
    class="relative w-full md:h-[85vh] md:min-h-[700px] flex md:items-end items-start justify-center overflow-hidden bg-background mt-20"
  >
    <!-- Video de fondo que ocupa todo el Hero (si hay video reproducir; si no mostrar imagen) -->
    <div class="absolute inset-x-0 top-0 z-0 h-[56.25vw] md:inset-0 md:h-full">
      {project.video ? (
        <>
          <video
            id="project-cover-video"
            src={project.video}
            poster={project.image}
            class="w-full h-full object-cover scale-105 animate-image-reveal brightness-[0.5] saturate-[1.2]"
            autoplay
            controls
            muted
            playsinline
          ></video>

          <!-- Poster que se muestra cuando el video termina o se detiene -->
          <img
            id="project-cover-poster"
            src={project.image}
            alt={`${project.title} Cover`}
            class="w-full h-full object-cover scale-105 brightness-[0.5] saturate-[1.2]"
            style="display: none;"
          />

        </>
      ) : (
        <img
          src={project.image}
          alt={`${project.title} Cover`}
          class="w-full h-full object-cover scale-105 animate-image-reveal brightness-[0.5] saturate-[1.2]"
        />
      )}
    </div>

    <!-- NUEVOS CONTROLES AISLADOS EN Z-50 -->
    {project.video && (
      <div id="video-controls" style="display: none;" class="absolute top-4 right-4 z-[100] flex gap-2">
        <button
          id="btn-fullscreen"
          type="button"
          class="inline-flex items-center justify-center p-3 md:px-4 md:py-2 rounded-full bg-black/50 backdrop-blur-md border border-white/20 text-sm text-white hover:bg-black/70 active:bg-black/80"
          title="Pantalla Completa"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:mr-2"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>
          <span class="hidden md:inline font-medium">Fullscreen</span>
        </button>

        <button
          id="btn-stop-video"
          type="button"
          class="inline-flex items-center justify-center p-3 md:px-4 md:py-2 rounded-full bg-red-600/60 backdrop-blur-md border border-red-500/50 text-sm text-white hover:bg-red-600/80 active:bg-red-600/90"
          title="Cerrar Video"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:mr-2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          <span class="hidden md:inline font-medium">Detener</span>
        </button>
      </div>
    )}

    <!-- PLAY BUTTON PARA CELULAR Y PC -->
    {project.video && (
      <button
        id="btn-play-overlay"
        style="display: none;"
        type="button"
        class="absolute top-4 right-4 z-[100] inline-flex items-center gap-2 p-3 md:px-4 md:py-2 rounded-full bg-black/60 backdrop-blur-md border border-white/20 text-sm text-white hover:bg-black/80 active:bg-black/90"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
        <span class="hidden md:inline font-medium">Ver Video</span>
      </button>
    )}

    <!-- Nota flotante sobre la imagen -->
    <div class="container relative z-20 mx-auto px-6 pt-[56.25vw] md:pt-0 pb-20 md:pb-200">
      <div id="hero-note" style={project.video ? "display: none;" : ""} class="md:absolute md:top-1/2 md:right-6 md:transform md:-translate-y-1/2 w-full md:max-w-md">
          <div class="bg-background/80 backdrop-blur-lg p-4 sm:p-8 shadow-lg rounded-3xl">
          <div class="flex flex-wrap gap-2 justify-center mb-8">
            <span
              class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-[0.3em] bg-primary/20 text-primary border border-primary/30 backdrop-blur-md shadow-2xl shadow-primary/20"
            >
              {project.category}
            </span>
          </div>

          <h1
            class="text-3xl sm:text-7xl md:text-6xl lg:text-7xl font-black tracking-tighter text-foreground mb-8 leading-[0.9] drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)]"
          >
            {project.title.split(' ').map((word, i) => (
              <span
                class={
                  i % 2 !== 0
                    ? "text-transparent bg-clip-text bg-gradient-to-r from-primary via-accent to-blue-400"
                    : ""
                }
              >
                {word}{' '}
              </span>
            ))}
          </h1>

          <p
            class="max-w-3xl text-sm md:text-xl font-medium text-muted-foreground leading-relaxed mb-8 drop-shadow-lg"
          >
            {project.shortDesc}
          </p>

          <div class="flex flex-col sm:flex-row gap-3 sm:gap-6 justify-center w-full sm:w-auto">
            <a
              href="#detalles"
              class="inline-flex items-center justify-center gap-3 h-10 sm:h-16 px-4 sm:px-12 rounded-lg sm:rounded-2xl bg-primary text-primary-foreground font-bold text-sm sm:text-lg hover:scale-105 transition-all duration-300 shadow-[0_20px_50px_-15px_rgba(var(--primary-rgb),0.5)]"
            >
              Explorar sistema
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="7 13 12 18 17 13"></polyline>
                <polyline points="7 6 12 11 17 6"></polyline>
              </svg>
            </a>
            <a
              href={`https://wa.me/59169867332?text=Hola%20MiraCode!%20Estoy%20interesado%20en%20solicitar%20una%20cotizaci%C3%B3n%20para%20un%20sistema%20similar%20a%20*${encodeURIComponent(project.title)}*%20%F0%9F%91%8B`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 h-10 sm:h-16 px-4 sm:px-12 rounded-lg sm:rounded-2xl border-2 border-primary/20 bg-background/20 backdrop-blur-md text-foreground font-bold text-sm sm:text-lg hover:bg-background/40 transition-all duration-300 hover:border-primary/50"
            >
              Solicitar cotización
            </a>
            {project.video && (
              <button
                id="btn-play-hero"
                type="button"
                class="inline-flex items-center justify-center gap-2 h-10 sm:h-16 px-4 sm:px-8 rounded-lg sm:rounded-2xl border border-white/20 bg-black/20 backdrop-blur-md text-white font-bold text-sm sm:text-lg hover:bg-white/10 transition-all duration-300 shadow-[0_20px_50px_-15px_rgba(0,0,0,0.5)]"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                Ver Demo
              </button>
            )}
          </div>
        </div>
      </div>
    </div>
    </div>
    
    <!-- JS NATIVO ROBUSTO PARA MOBILE/DESKTOP -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const video = document.getElementById('project-cover-video') as HTMLVideoElement;
        if (!video) return;

        const poster = document.getElementById('project-cover-poster') as HTMLImageElement;
        const heroNote = document.getElementById('hero-note');
        
        const controlsGroup = document.getElementById('video-controls');
        const btnPlaySmall = document.getElementById('btn-play-overlay');
        const btnStop = document.getElementById('btn-stop-video');
        const btnFullscreen = document.getElementById('btn-fullscreen');
        const btnPlayBig = document.getElementById('btn-play-hero');

        // Función para cambiar interfaz a "Video Reproduciéndose"
        const showVideoPlaying = () => {
          if (poster) poster.style.display = 'none';
          video.style.display = 'block';
          
          if (heroNote) heroNote.style.display = 'none';     // Ocultamos la tarjeta molesta al 100%
          if (btnPlaySmall) btnPlaySmall.style.display = 'none'; 
          if (controlsGroup) controlsGroup.style.display = 'flex'; // Mostramos Stop y FS
        };

        // Función para cambiar interfaz a "Tarjeta Info" (Poster)
        const showInfoCard = () => {
          if (poster) poster.style.display = 'block';
          video.style.display = 'none';
          
          if (heroNote) heroNote.style.display = 'block';
          if (controlsGroup) controlsGroup.style.display = 'none';
          if (btnPlaySmall) btnPlaySmall.style.display = 'inline-flex';
        };

        // Escuchar cuando el video se acaba
        video.addEventListener('ended', showInfoCard);

        // Auto-play (muchos celulares lo bloquean)
        const p = video.play();
        if (p !== undefined) {
          p.then(() => showVideoPlaying()).catch(() => showInfoCard());
        }

        // --- BOTONES (usando click o pointerdown en vez de dudar) ---
        
        // Función general de binding para móviles
        const bindButton = (el: HTMLElement | null, action: () => void) => {
          if (!el) return;
          // Prevenimos que toque dos veces rápido o doble fire
          el.addEventListener('click', (e) => { e.preventDefault(); action(); });
          el.addEventListener('touchstart', (e) => { e.preventDefault(); action(); }, { passive: false });
        };

        // Jugar desde los botones
        const doPlay = () => {
          video.currentTime = 0;
          video.muted = false; // Intenta desmutear
          video.play().then(showVideoPlaying).catch(()=>{});
        };
        
        bindButton(btnPlayBig, doPlay);
        bindButton(btnPlaySmall, doPlay);

        // Detener video
        const doStop = () => {
          video.pause();
          showInfoCard();
          if (document.fullscreenElement) {
            document.exitFullscreen().catch(()=>{});
          }
        };
        bindButton(btnStop, doStop);

        // Pantalla Completa
        const doFullscreen = () => {
          if (!document.fullscreenElement) {
            if (video.requestFullscreen) video.requestFullscreen();
            else if ((video as any).webkitRequestFullscreen) (video as any).webkitRequestFullscreen();
          } else {
            if (document.exitFullscreen) document.exitFullscreen();
          }
        };
        bindButton(btnFullscreen, doFullscreen);
      });
    </script>
  </section>

  <!-- ── DETALLES Y CONTEXTO ────── -->
  <section id="detalles" class="py-20 bg-background scroll-mt-20">
    <div class="container mx-auto px-4 md:px-6 max-w-4xl">
      <!-- "The Problem" / Descripción completa -->
      <div class="lg:prose-xl mx-auto text-center mb-16">
        <h2
          class="text-3xl md:text-5xl font-extrabold tracking-tight mb-8 text-foreground"
        >
          Contexto del Proyecto
        </h2>
        <p
          class="text-muted-foreground leading-relaxed text-lg lg:text-xl font-medium"
        >
          {project.fullDesc}
        </p>
      </div>

      <!-- Features grid -->
      <div class="grid sm:grid-cols-2 gap-6">
        {
          project.features.map((f) => (
            <div class="flex items-start gap-4 p-6 rounded-3xl border border-border/40 bg-card/40 backdrop-blur-sm shadow-sm hover:border-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-primary/5 group">
              <div class="shrink-0 flex items-center justify-center w-10 h-10 rounded-2xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
              </div>
              <span class="text-base md:text-lg font-semibold leading-snug text-foreground/90 pt-1 transition-colors group-hover:text-foreground">
                {f}
              </span>
            </div>
          ))
        }
      </div>

      <!-- Tech Stack -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-16 mb-24">
        <span
          class="text-sm font-bold text-muted-foreground uppercase tracking-widest mr-2"
          >Stacks Utilizados:</span
        >
        {
          project.tags.map((t) => (
            <span class="px-5 py-2 text-sm font-bold rounded-full bg-secondary text-secondary-foreground border border-border/40 hover:border-primary/50 hover:bg-primary/5 cursor-default transition-all">
              {t}
            </span>
          ))
        }
      </div>

      <!-- Enlace a proyecto desplegado (si existe) -->
      {project.liveUrl && (
        <div class="text-center mb-24">
          <a
            href={project.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-8 py-4 bg-primary text-primary-foreground font-bold rounded-2xl shadow-lg hover:scale-105 transition-transform"
          >
            Ver proyecto desplegado
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- ── CRONOLOGÍA / RECORRIDO DEL SISTEMA ──────── -->
  <section class="py-12 pb-32 relative overflow-hidden bg-dot-pattern">
    <div class="container mx-auto px-4 md:px-6 max-w-6xl">
      <div class="text-center mb-20">
        <h2
          class="text-3xl md:text-6xl font-black tracking-tight text-foreground"
        >
          Recorrido del Sistema
        </h2>
        <p class="text-muted-foreground mt-4 text-xl font-medium">
          Vistas y flujos principales de la solución implementada.
        </p>
      </div>

      <!-- Timeline Container -->
      <div class="relative w-full max-w-5xl mx-auto">
        <!-- Línea Guia de fondo -->
        <div
          class="absolute left-11 sm:left-[5.5rem] top-10 bottom-10 w-0.5 bg-border/40 -z-10"
        >
        </div>

        <div class="flex flex-col gap-4">
          {
            project.sections.map((section, idx) => (
              <TimelineItem
                title={section.title}
                description={section.description}
                badge={section.badge}
                image={section.image ?? ''}
                index={idx}
                total={project.sections.length}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ── CALL TO ACTION FINAL ──────────────────────────────── -->
  <section class="relative py-32 border-t border-border/40 overflow-hidden">
    <!-- Efecto en el fondo -->
    <div
      class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/10 via-background to-background"
    >
    </div>

    <div class="container mx-auto px-4 text-center max-w-4xl">
      <h2
        class="text-4xl md:text-7xl font-black tracking-tighter mb-8 text-foreground"
      >
        ¿Tu negocio necesita una <br />
        <span class="text-primary italic">Solución similar?</span>
      </h2>
      <p
        class="text-xl md:text-2xl text-muted-foreground mb-12 font-medium max-w-2xl mx-auto leading-relaxed"
      >
        Cada proyecto es único. Podemos diseñar y desarrollar el sistema que {
          project.title
        } necesitaba, o superar tus expectativas con algo nuevo.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a
          href={`https://wa.me/59169867332?text=Hola%20MiraCode!%20Vi%20el%20proyecto%20*${encodeURIComponent(project.title)}*%20y%20me%20interesa%20una%20soluci%C3%B3n%20similar%20para%20mi%20negocio.%20%C2%BFPodr%C3%ADan%20darme%20m%C3%A1s%20informaci%C3%B3n%3F%20%F0%9F%91%8B`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 h-16 px-12 rounded-2xl bg-primary text-primary-foreground font-bold text-lg shadow-2xl shadow-primary/30 hover:scale-105 transition-all duration-300"
        >
          Iniciar cotización ahora
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="9 18 15 12 9 6"></polyline></svg
          >
        </a>
        <a
          href="/#portfolio"
          class="inline-flex items-center justify-center gap-3 h-16 px-12 rounded-2xl border-2 border-border bg-card/30 hover:bg-card text-foreground font-bold text-lg transition-all duration-300"
        >
          Explorar Portafolio
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Main>

<style>
  /* Patrón de puntos para el fondo del Timeline */
  .bg-dot-pattern {
    background-image: radial-gradient(
      hsl(var(--muted-foreground) / 0.2) 1px,
      transparent 1px
    );
    background-size: 32px 32px;
  }

  /* Animaciones custom para el Hero */
  .animate-image-reveal {
    animation: imageReveal 2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .animate-fade-up {
    opacity: 0;
    transform: translateY(40px);
    animation: fadeUp 1s ease-out 0.4s forwards;
  }

  @keyframes imageReveal {
    from {
      transform: scale(1.15);
      filter: blur(12px) brightness(0.3);
    }
    to {
      transform: scale(1);
      filter: blur(0px) brightness(1);
    }
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
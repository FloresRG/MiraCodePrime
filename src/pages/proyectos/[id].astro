---
// src/pages/proyectos/[id].astro
import Main from '../../layouts/main.astro';
import { Navbar } from '@/components/Navbar';
import { Footer } from '@/components/Footer';
import { projects, getProject } from '@/lib/projects';
import ProjectScreenshotSection from '@/components/ProjectScreenshotSection.astro';

// Genera una ruta estática por cada proyecto
export function getStaticPaths() {
  return projects.map(p => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const project = getProject(id!);

// Redirige a 404 si no existe
if (!project) return Astro.redirect('/404');

// Imagen placeholder — cuando tengas las reales, importalas aquí
import dashImg from '@/assets/dashboard.png';

// Assign the placeholder to every section image for now
const sectionImages = project.sections.map(() => dashImg);
const coverImage = dashImg;
---

<Main title={`${project.title} | MiraCode`}>
  <Navbar client:load />

  <!-- ── HERO DEL PROYECTO ─────────────────────────────────── -->
  <section class="relative pt-28 pb-0 overflow-hidden">
    <!-- Glow de fondo -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class={`absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-gradient-to-b ${project.color} opacity-10 rounded-full blur-3xl`}></div>
    </div>

    <div class="container mx-auto px-4 md:px-6">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-8 hero-fade" aria-label="Breadcrumb">
        <a href="/" class="hover:text-foreground transition-colors">Inicio</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/proyectos" class="hover:text-foreground transition-colors">Proyectos</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-foreground font-medium">{project.title}</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-12 items-center pb-16">
        <!-- Texto -->
        <div class="flex flex-col gap-6">
          <!-- Badge categoría -->
          <div class="hero-fade delay-50">
            <span class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold bg-gradient-to-r ${project.color} text-white shadow-sm`}>
              {project.category}
            </span>
          </div>

          <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight hero-fade delay-100">
            <span class="bg-gradient-to-r from-foreground to-muted-foreground bg-clip-text text-transparent">
              {project.title}
            </span>
          </h1>

          <p class="text-lg text-muted-foreground leading-relaxed max-w-xl hero-fade delay-150">
            {project.fullDesc}
          </p>

          <!-- Features -->
          <ul class="space-y-2.5 hero-fade delay-200">
            {project.features.map(f => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5 text-primary"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                <span class="text-sm text-foreground/90">{f}</span>
              </li>
            ))}
          </ul>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 hero-fade delay-250">
            {project.tags.map(t => (
              <span class="text-xs font-semibold px-3 py-1 rounded-full bg-primary/10 text-primary border border-primary/20">
                {t}
              </span>
            ))}
          </div>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row gap-3 pt-2 hero-fade delay-300">
            <a
              href="/contacto"
              class="inline-flex items-center justify-center gap-2 h-11 px-6 rounded-xl bg-primary text-primary-foreground font-semibold text-sm shadow-lg shadow-primary/25 hover:shadow-primary/40 transition-all duration-300 hover:-translate-y-0.5 overflow-hidden relative group"
            >
              <span class="absolute inset-0 -translate-x-full group-hover:animate-shine bg-gradient-to-r from-transparent via-white/20 to-transparent"></span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Quiero algo así
            </a>
            <a
              href="/proyectos"
              class="inline-flex items-center justify-center gap-2 h-11 px-6 rounded-xl border border-border bg-background/50 text-foreground font-semibold text-sm hover:bg-accent/50 transition-all duration-300 hover:-translate-y-0.5"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
              Ver todos los proyectos
            </a>
          </div>
        </div>

        <!-- Cover image del proyecto -->
        <div class="relative group hero-fade delay-100">
          <div class={`absolute -inset-1 bg-gradient-to-r ${project.color} rounded-2xl blur opacity-25 group-hover:opacity-40 transition-opacity duration-500`}></div>
          <div class="relative overflow-hidden rounded-2xl border bg-card/50 backdrop-blur-sm shadow-2xl aspect-[16/10]">
            <div class={`absolute inset-0 bg-gradient-to-br ${project.color} opacity-60 z-10`}></div>
            <img
              src={coverImage.src}
              alt={`${project.title} — vista principal`}
              width={coverImage.width}
              height={coverImage.height}
              loading="eager"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 will-change-transform"
            />
          </div>
          <!-- Decoración -->
          <div class="absolute -bottom-5 -right-5 w-20 h-20 bg-primary/20 rounded-full blur-2xl animate-pulse"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── DIVISOR ─────────────────────────────────────────── -->
  <div class="container mx-auto px-4 md:px-6">
    <div class="flex items-center gap-4 py-4">
      <div class="h-px flex-1 bg-border/60"></div>
      <span class="text-xs font-bold text-muted-foreground uppercase tracking-widest px-3">Capturas del sistema</span>
      <div class="h-px flex-1 bg-border/60"></div>
    </div>
  </div>

  <!-- ── SECCIONES DE CAPTURAS (una por pantalla del sistema) ── -->
  {project.sections.map((section, i) => (
    <ProjectScreenshotSection
      title={section.title}
      description={section.description}
      image={sectionImages[i]}
      imagePosition={section.imagePosition}
      badge={section.badge}
      index={i}
    />
  ))}

  <!-- ── CTA FINAL ───────────────────────────────────────── -->
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-4 md:px-6 text-center">
      <div class="relative inline-block mb-6">
        <div class={`absolute inset-0 bg-gradient-to-r ${project.color} opacity-20 rounded-full blur-2xl`}></div>
        <span class={`relative inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-bold bg-gradient-to-r ${project.color} text-white`}>
          ¿Te interesa este tipo de solución?
        </span>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
        <span class="bg-gradient-to-r from-foreground to-muted-foreground bg-clip-text text-transparent">
          Construyamos algo así,
        </span>
        <br />
        <span class={`bg-gradient-to-r ${project.color} bg-clip-text text-transparent`}>
          pero tuyo.
        </span>
      </h2>
      <p class="text-muted-foreground text-lg max-w-xl mx-auto mb-8">
        Cada proyecto empieza con una conversación. Contanos tu idea y te decimos cómo lo haríamos.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contacto"
          class="inline-flex items-center justify-center gap-2 h-12 px-8 rounded-xl bg-primary text-primary-foreground font-bold text-sm shadow-xl shadow-primary/30 hover:shadow-primary/50 transition-all duration-300 hover:-translate-y-1 overflow-hidden relative group"
        >
          <span class="absolute inset-0 -translate-x-full group-hover:animate-shine bg-gradient-to-r from-transparent via-white/20 to-transparent"></span>
          Hablar con el equipo
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="/proyectos"
          class="inline-flex items-center justify-center gap-2 h-12 px-8 rounded-xl border border-border bg-background/50 text-foreground font-bold text-sm hover:bg-accent/50 transition-all duration-300 hover:-translate-y-1"
        >
          Ver más proyectos
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Main>

<script>
  // Hero fade-in al cargar
  document.querySelectorAll('.hero-fade').forEach(el => {
    const delayClass = [...(el as HTMLElement).classList].find(c => c.startsWith('delay-'));
    const delay = delayClass ? parseInt(delayClass.replace('delay-', '')) : 0;
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(18px)';
    (el as HTMLElement).style.transition = 'opacity 0.6s ease, transform 0.6s cubic-bezier(.22,1,.36,1)';
    setTimeout(() => {
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'translateY(0)';
    }, 80 + delay);
  });
</script>

<style>
  .bg-clip-text { -webkit-background-clip: text; background-clip: text; }
  @keyframes shine { 100% { transform: translateX(200%); } }
  .animate-shine { animation: shine 1s ease-in-out; }
</style>

---
import Main from "../../layouts/main.astro";
import { Navbar } from "@/components/Navbar";
import { Footer } from "@/components/Footer";
import { ServicePageTimeline } from "@/components/ServicePageTimeline";
import { services } from "@/data/services";
import { MoveLeft } from "lucide-react";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Main title={`${service.title} | MiraCode Services`}>
  <Navbar client:load />

  <main class="pt-20">
    {/* Hero Header Section */}
    <div class="relative h-[60vh] w-full overflow-hidden">
      
      <img
        src={service.image}
        alt={service.title}
        class="size-full object-cover"
      />

      {/* Link para volver - posicionado arriba a la izquierda */}
      <div class="absolute top-24 left-6 md:left-10 z-30">
        <a
          href="/#services"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-blue-950/60 backdrop-blur-md border border-blue-400/20 text-blue-100 hover:text-blue-50 hover:border-blue-400/40 hover:bg-blue-950/80 transition-all duration-300 font-semibold text-sm shadow-lg shadow-blue-950/30"
        >
          <MoveLeft
            class="size-4 group-hover:-translate-x-1 transition-transform"
          />
          <span>Volver a Servicios</span>
        </a>
      </div>

      {/* Nota/Card principal arriba a la derecha con estilo azul marino */}
      <div class="absolute top-24 right-6 md:right-10 z-30 w-96 max-w-[90%]">
        <div class="rounded-2xl p-6 bg-blue-950/70 backdrop-blur-2xl border border-blue-400/20 shadow-2xl shadow-blue-950/50 hover:shadow-blue-500/20 transition-all duration-300 hover:border-blue-400/30 hover:-translate-y-1">
          
          {/* Icono y categoría */}
          <div class="flex items-center gap-4 mb-4">
            <div class="size-14 rounded-xl bg-blue-400/20 border border-blue-400/30 flex items-center justify-center shadow-lg shadow-blue-400/10">
              {
                service.icon &&
                  (() => {
                    const Icon = service.icon;
                    return <Icon class="size-7 text-blue-200" />;
                  })()
              }
            </div>
            <span class="text-xs font-bold tracking-[0.2em] uppercase text-blue-300">
              Servicio Especializado
            </span>
          </div>

          {/* Título */}
          <h1 class="text-3xl md:text-4xl font-bold text-white mb-3 leading-tight tracking-tight">
            {service.title}
          </h1>

          {/* Descripción */}
          <p class="text-sm text-blue-200/70 font-medium leading-relaxed">
            {service.description}
          </p>

          {/* Botón CTA opcional */}
          <div class="mt-5 pt-5 border-t border-blue-400/20">
            <a
              href="#proceso"
              class="inline-flex items-center justify-center gap-2 h-10 px-6 rounded-xl bg-blue-400 text-blue-950 font-semibold text-sm hover:bg-blue-300 transition-all duration-300 hover:scale-105 shadow-lg shadow-blue-400/25 w-full sm:w-auto"
            >
              Ver nuestro proceso
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="animate-bounce"
              >
                <path d="M12 5v14"></path>
                <path d="m19 12-7 7-7-7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>

      {/* Overlay gradiente en la parte inferior */}
      <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-slate-950/60 to-transparent z-10"></div>
    </div>

    {/* Content Section */}
    <section id="proceso" class="py-20 bg-background relative overflow-hidden">
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
      >
      </div>

      <div class="container mx-auto px-4">
        <div class="text-center mb-20">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
            Nuestro Proceso
          </h2>
          <p class="text-muted-foreground">
            Transparencia y excelencia en cada etapa de ejecución.
          </p>
        </div>

        <ServicePageTimeline service={service} client:load />
      </div>
    </section>
  </main>

  <Footer />
</Main>

<style>
  main {
    min-height: 100vh;
  }
</style>
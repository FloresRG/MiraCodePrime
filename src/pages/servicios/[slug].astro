---
import Main from "../../layouts/main.astro";
import { Navbar } from "@/components/Navbar";
import { Footer } from "@/components/Footer";
import { ServicePageTimeline } from "@/components/ServicePageTimeline";
import { services } from "@/data/services";
import { MoveLeft } from "lucide-react";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Main title={`${service.title} | MiraCode Services`}>
  <Navbar client:load />

  <main class="relative bg-background overflow-hidden">
    {/* Hero Header Section */}
    <div class="relative h-[80vh] min-h-[600px] w-full flex items-center justify-center overflow-hidden bg-background pt-20">
      
      <div class="absolute inset-0 z-0">
        <img
          src={service.image}
          alt={service.title}
          class="size-full object-cover brightness-[0.4] saturate-[1.1] scale-105 animate-image-reveal"
        />
        {/* Mesh Gradient Overlay */}
        <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-background to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-accent/5"></div>
      </div>

      {/* Link para volver - posicionado arriba a la izquierda */}
      <div class="absolute top-24 left-6 md:left-10 z-30">
        <a
          href="/#services"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-background/20 backdrop-blur-xl border border-white/10 text-foreground/80 hover:text-foreground hover:border-primary/50 hover:bg-background/40 transition-all duration-300 font-bold text-xs uppercase tracking-widest shadow-2xl"
        >
          <MoveLeft
            class="size-4"
          />
          <span>Ver Servicios</span>
        </a>
      </div>

      {/* Centered Content */}
      <div class="container relative z-20 mx-auto px-6 flex flex-col items-center text-center animate-fade-up">
         <div class="flex items-center justify-center size-20 md:size-28 rounded-3xl bg-primary/20 border border-primary/30 backdrop-blur-xl mb-8 shadow-2xl shadow-primary/20">
           {service.icon && (() => {
             const Icon = service.icon;
             return <Icon class="size-10 md:size-14 text-primary drop-shadow-[0_0_15px_rgba(var(--primary-rgb),0.4)]" />;
           })()}
         </div>
         
         <span class="text-xs md:text-sm font-black tracking-[0.4em] uppercase text-primary mb-6 drop-shadow-md">
           Servicio Especializado
         </span>
         
         <h1 class="text-5xl md:text-8xl lg:text-[9rem] font-black text-foreground mb-8 leading-[0.8] tracking-tighter drop-shadow-2xl">
           {service.title}
         </h1>
         
         <p class="max-w-3xl text-xl md:text-3xl font-medium text-muted-foreground leading-relaxed mb-12 drop-shadow-xl">
           {service.description}
         </p>
         
         <a
           href="#proceso"
           class="inline-flex items-center justify-center gap-3 h-16 px-12 rounded-2xl bg-primary text-primary-foreground font-extrabold text-lg hover:scale-105 transition-all duration-500 shadow-[0_20px_50px_-15px_rgba(var(--primary-rgb),0.5)] group"
         >
           Explorar Proceso
           <svg
             xmlns="http://www.w3.org/2000/svg"
             width="22"
             height="22"
             viewBox="0 0 24 24"
             fill="none"
             stroke="currentColor"
             stroke-width="3"
             stroke-linecap="round"
             stroke-linejoin="round"
             class="group-hover:translate-y-1 transition-transform"
           >
             <path d="m7 10 5 5 5-5"></path>
           </svg>
         </a>
      </div>
    </div>

    {/* Content Section */}
    <section id="proceso" class="py-20 bg-background relative overflow-hidden">
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
      >
      </div>

      <div class="container mx-auto px-4">
        <div class="text-center mb-20">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
            Nuestro Proceso
          </h2>
          <p class="text-muted-foreground">
            Transparencia y excelencia en cada etapa de ejecución.
          </p>
        </div>

        <ServicePageTimeline service={service} client:load />
      </div>
    </section>
  </main>

  <Footer />
</Main>

<style>
  main {
    min-height: 100vh;
  }
</style>
---
import MainLayout from "../layouts/main.astro";
---

<MainLayout title="1 Bs. de Comisión — MiraCode" description="Por solo 1 Bs. de comisión, accede a todos nuestros proyectos y sistemas.">
  <main class="min-h-screen bg-background text-foreground flex flex-col items-center justify-center relative overflow-hidden px-5 py-24">

    <!-- Fondo decorativo -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-primary/20 blur-[120px] opacity-60"></div>
      <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-accent/20 blur-[100px] opacity-40"></div>
    </div>

    <!-- Badge superior -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary/40 bg-primary/10 text-primary text-xs font-semibold mb-8 tracking-widest uppercase">
      <span class="size-2 rounded-full bg-primary animate-pulse"></span>
      Oferta Especial
    </div>

    <!-- Tarjeta principal -->
    <div class="relative w-full max-w-2xl rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl shadow-[0_0_80px_rgba(var(--primary-rgb),0.15)] p-8 md:p-14 text-center">
      <!-- Brillo interno -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-3/4 bg-gradient-to-r from-transparent via-primary/60 to-transparent"></div>

      <!-- Precio -->
      <div class="flex items-end justify-center gap-2 mb-6">
        <span class="text-8xl md:text-[9rem] font-black leading-none text-transparent bg-clip-text bg-gradient-to-br from-primary via-accent to-blue-400 drop-shadow-[0_0_40px_rgba(var(--primary-rgb),0.4)]">
          1
        </span>
        <span class="text-4xl md:text-5xl font-black text-foreground/80 mb-4">Bs.</span>
      </div>

      <!-- Título -->
      <h1 class="text-2xl md:text-4xl font-black tracking-tight mb-4 text-foreground">
        Por solo <span class="text-primary">1 Bs. de comisión</span>
      </h1>

      <!-- Descripción -->
      <p class="text-base md:text-lg text-foreground/60 leading-relaxed max-w-lg mx-auto mb-10">
        Accede a todos nuestros proyectos y sistemas desarrollados. Con una comisión mínima de
        <strong class="text-foreground/90">1 Boliviano</strong>, obtienes acceso completo a nuestro catálogo
        de soluciones de software premium.
      </p>

      <!-- Separador -->
      <div class="flex items-center gap-4 mb-10">
        <div class="flex-1 h-px bg-white/10"></div>
        <span class="text-foreground/30 text-xs uppercase tracking-widest">¿Qué incluye?</span>
        <div class="flex-1 h-px bg-white/10"></div>
      </div>

      <!-- Features -->
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-left mb-10">
        {[
          "Acceso a todos los proyectos",
          "Soporte técnico incluido",
          "Actualizaciones gratuitas",
          "Código fuente disponible",
          "Instalación asistida",
          "Documentación completa",
        ].map((item) => (
          <li class="flex items-center gap-3 bg-white/5 rounded-xl px-4 py-3 border border-white/5">
            <span class="size-5 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-sm text-foreground/80 font-medium">{item}</span>
          </li>
        ))}
      </ul>

      <!-- CTA -->
      <a
        href="/proyectos"
        class="inline-flex items-center justify-center gap-2 w-full sm:w-auto px-8 py-4 rounded-2xl bg-primary text-primary-foreground font-bold text-base shadow-[0_0_30px_rgba(var(--primary-rgb),0.4)] hover:shadow-[0_0_50px_rgba(var(--primary-rgb),0.7)] hover:scale-105 transition-all duration-300"
      >
        Explorar Proyectos
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Footer note -->
    <p class="mt-8 text-xs text-foreground/30 text-center max-w-sm">
      * La comisión de 1 Bs. aplica por proyecto seleccionado. Precios finales sujetos a negociación.
    </p>
  </main>
</MainLayout>

<style>
  @keyframes gradient-x {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient-x {
    background-size: 200% 200%;
    animation: gradient-x 4s ease infinite;
  }
</style>
